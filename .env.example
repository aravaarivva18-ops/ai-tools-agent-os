# =============================================================================
# AI Tools Workspace — Environment Variables
# =============================================================================
# Скопируйте этот файл в .env и заполните реальными значениями:
#   cp .env.example .env
# =============================================================================

# --- ScraperAPI (веб-скрапинг с обходом антибот-защиты) ---
# Получить ключ: https://www.scraperapi.com/
SCRAPER_API_KEY=your_scraper_api_key_here

# --- PostgreSQL (агентская память и RAG-векторы) ---
POSTGRES_USER=rus
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=ai_tools_memory
DATABASE_URL=postgresql://rus:your_secure_password_here@db:5432/ai_tools_memory

# --- Obsidian Vault ---
OBSIDIAN_VAULT_PATH=./vault
